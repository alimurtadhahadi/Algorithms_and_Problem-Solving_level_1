string EnterNewPIN() {
    string NewPIN; cout << "Please enter your new PIN: ";
    getline(cin, NewPIN); return NewPIN; // Return established code
}
string TryToLogin(string ApprovedPIN) {
    ClearScreen(); string Attempt; int Tries = 3;
    do {
        cout << "Please enter your PIN to access balance: "; getline(cin, Attempt);
        if (Login(ApprovedPIN, Attempt)) return Attempt; // Safe immediate exit code

        Tries--; ClearScreen(); cout << "\a"; // Failure block decrement
        if (Tries > 0) ShowRedAlertEffect(Tries);
    } while (Tries > 0);

    ShowLockoutScreen(); return ""; // Blocked hacker terminal exit
}
void PrintBalance() {
    string ApprovedPIN = EnterNewPIN();
    string Attempt = TryToLogin(ApprovedPIN);
    if (Login(ApprovedPIN, Attempt)) ShowGreenAlert(); // Trigger success vault
}
