#include <iostream>
#include <string>
#include <windows.h> 
using namespace std;
void ClearScreen() { cout << "\033[H\033[J"; } // Wipes console screen cleanly
bool Login(string ApprovedPIN, string AttemptToOpenPIN) {
    return (AttemptToOpenPIN == ApprovedPIN); // Direct boolean expression evaluation
}
void ShowRedAlertEffect(int RemainingTries) {
    system("color 4F"); // Red background
    cout << "==================================\n   WRONG PIN!!! ACCESS DENIED!!!\n==================================\n";
    Sleep(1000); system("color 0F"); ClearScreen(); // Reset color and clear screen
    cout << "Try again. You have " << RemainingTries << " tries left.\n";
}
void ShowLockoutScreen() {
    ClearScreen();
    cout << "|=======================================================|\n|  YOUR ACCOUNT IS LOCKED! CONTACT THE BANK TO OPEN IT  |\n|=======================================================| \n";
    for (int i = 0; i < 10; i++) { // Alarm loop flashes red/black
        system("color 4F"); Sleep(500);
        system("color 0F"); Sleep(500);
    }
}
