#include <iostream>
#include <string>
using namespace std;
int readBase()
{
	int Num;
	cout << "please enter number to power it :";
	cin >> Num;
	return Num;
}
int readExponent()
{
	int Pow;
	cout << "please enter the power :";
	cin >> Pow;
	return Pow;
}
int PowerOfExponent(int Base, int Exponent)
{
	if (Exponent == 0) { return 1; }
	int P = 1;
	for (int i = 1; i <= Exponent; i++)
	{
		P = P * Base;
	}
	return P;
}
int main()
{
	int Base = readBase();
	int Exponent = readExponent();
	cout << "the result of (" << Base << "^" << Exponent << ") is :" << PowerOfExponent(Base, Exponent);
	return 0;
}
