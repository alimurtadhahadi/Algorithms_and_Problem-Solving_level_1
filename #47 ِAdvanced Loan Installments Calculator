#include <iostream>
#include <string>

using namespace std;

void ClearScreen()
{
    cout << "\033[H\033[J";
}

struct stUserInstallments
{
    float LoanAmount, MonthlyInstallment;
};

float ReadPositiveNumber(string Message)
{
    float Number = 0;
    do
    {
        cout << Message;  
        cin >> Number; 
    } while (Number <= 0);  

    return Number; 
}

stUserInstallments ReadUserInstallments()
{
    stUserInstallments UserInstallments;
    UserInstallments.LoanAmount = ReadPositiveNumber("Please enter loan amount: ");
    UserInstallments.MonthlyInstallment = ReadPositiveNumber("Please enter Monthly Installment: ");
    return UserInstallments;
}

float TotalMonths(stUserInstallments UserInstallments)
{
    return UserInstallments.LoanAmount / UserInstallments.MonthlyInstallment;
}

void PrintResults()
{
    stUserInstallments UserInstallments = ReadUserInstallments();
    float Months = TotalMonths(UserInstallments);
    
    ClearScreen();
    cout << "=================================================" << endl;
    cout << "Your  Loan  Amount  is      :" << UserInstallments.LoanAmount << endl;
    cout << "Your Monthly Installment is :" << UserInstallments.MonthlyInstallment << endl;
    cout << "==================================================" << endl;
    cout << "Your Total month is :" << Months << endl;
}

int main()
{
    PrintResults();
    return 0;
}
